---
export interface Props {
  name: string;
  codename?: string;
  role?: string;
  stats?: Record<string, number>;
  glyph?: string; // single character or emoji used as portrait
  accent?: 'hot' | 'gold' | 'neon' | 'acid' | 'blood';
}
const {
  name,
  codename,
  role,
  stats = { POW: 7, TEC: 6, SPD: 5, DEF: 4 },
  glyph = '?',
  accent = 'hot',
} = Astro.props;
---
<article class={`card accent-${accent}`} tabindex="0">
  <div class="card-portrait">
    <div class="portrait-grid">
      <span class="glyph">{glyph}</span>
    </div>
    <div class="codename">{codename ?? '???'}</div>
  </div>
  <div class="card-body">
    <h3 class="card-name">{name}</h3>
    {role && <p class="card-role">{role}</p>}
    <ul class="stats">
      {Object.entries(stats).map(([key, val]) => (
        <li class="stat">
          <span class="stat-key">{key}</span>
          <span class="stat-bar">
            <span class="stat-fill" style={`--w:${Math.min(10, val) * 10}%`}></span>
          </span>
        </li>
      ))}
    </ul>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg-1);
    border: 3px solid var(--ink);
    box-shadow: 6px 6px 0 var(--shadow);
    transition: transform 120ms ease, box-shadow 120ms ease;
    position: relative;
    cursor: pointer;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: -3px;
    border: 1px solid var(--hot);
    pointer-events: none;
    opacity: 0;
    transition: opacity 120ms ease;
  }
  .card:hover, .card:focus {
    transform: translate(-3px, -3px);
    box-shadow: 9px 9px 0 var(--shadow);
    outline: none;
  }
  .card:hover::before, .card:focus::before { opacity: 1; }

  .card-portrait {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background:
      repeating-linear-gradient(45deg,
        var(--bg-2) 0 12px,
        var(--bg-1) 12px 24px);
    border-bottom: 3px solid var(--ink);
  }
  .portrait-grid {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }
  .glyph {
    font-family: var(--font-pixel);
    font-size: clamp(48px, 9vw, 96px);
    color: var(--ink);
    text-shadow:
      4px 4px 0 var(--shadow),
      -2px -2px 0 var(--accent-color),
      2px 2px 0 var(--accent-color);
    filter: drop-shadow(0 0 12px var(--accent-color));
  }
  .codename {
    position: absolute;
    bottom: 6px;
    left: 6px;
    font-family: var(--font-pixel);
    font-size: 8px;
    background: var(--bg-0);
    color: var(--accent-color);
    padding: 4px 6px;
    border: 1px solid var(--ink);
    letter-spacing: 1px;
  }

  .card-body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .card-name {
    font-family: var(--font-pixel);
    font-size: 13px;
    color: var(--ink);
    letter-spacing: 1px;
  }
  .card-role {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-dim);
  }

  .stats { list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .stat {
    display: grid;
    grid-template-columns: 36px 1fr;
    align-items: center;
    gap: 8px;
    font-family: var(--font-pixel);
    font-size: 8px;
    color: var(--ink-dim);
  }
  .stat-bar {
    height: 8px;
    background: var(--bg-2);
    border: 1px solid var(--shadow);
    position: relative;
  }
  .stat-fill {
    position: absolute;
    inset: 0;
    width: var(--w);
    background: linear-gradient(
      to right,
      var(--accent-color) 0%,
      var(--gold) 100%
    );
    box-shadow: inset 0 -2px 0 rgba(0,0,0,0.3);
  }

  .accent-hot { --accent-color: var(--hot); }
  .accent-gold { --accent-color: var(--gold); }
  .accent-neon { --accent-color: var(--neon); }
  .accent-acid { --accent-color: var(--acid); }
  .accent-blood { --accent-color: var(--blood); }
</style>
