---
export interface Props {
  name: string;
  codename?: string;
  role?: string;
  stats?: Record<string, number>;
  image?: string;        // Path to sprite image, e.g. "/sprites/round-01.png"
  accent?: 'brick' | 'gold' | 'teal' | 'sienna';
}

const {
  name,
  codename,
  role,
  stats = { POW: 7, TEC: 6, SPD: 5, DEF: 4 },
  image,
  accent = 'brick',
} = Astro.props;
---
<article class={`card accent-${accent}`} tabindex="0">
  <div class="card-portrait">
    <div class="portrait-bg" aria-hidden="true"></div>
    {image
      ? <img src={image} alt={name} class="portrait-img" />
      : (
        <div class="portrait-placeholder">
          <span class="ph-tag">SPRITE  PENDING</span>
          <span class="ph-hint">drop image at<br/><code>/sprites/&lt;file&gt;</code></span>
        </div>
      )
    }
    <div class="codename">{codename ?? '???'}</div>
  </div>
  <div class="card-body">
    <h3 class="card-name">{name}</h3>
    {role && <p class="card-role">{role}</p>}
    <ul class="stats">
      {Object.entries(stats).map(([key, val]) => (
        <li class="stat">
          <span class="stat-key">{key}</span>
          <span class="stat-bar">
            <span class="stat-fill" style={`--w:${Math.min(10, val) * 10}%`}></span>
          </span>
        </li>
      ))}
    </ul>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 3px solid var(--ink);
    box-shadow: 5px 5px 0 var(--shadow);
    transition: transform 120ms ease, box-shadow 120ms ease;
    position: relative;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: -3px;
    border: 1px solid var(--accent-color);
    pointer-events: none;
    opacity: 0;
    transition: opacity 120ms ease;
  }
  .card:hover, .card:focus {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 var(--shadow);
    outline: none;
  }
  .card:hover::before, .card:focus::before { opacity: 1; }

  .card-portrait {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-bottom: 3px solid var(--ink);
  }
  /* Painted accent backdrop */
  .portrait-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        var(--accent-color) 0%,
        color-mix(in srgb, var(--accent-color) 65%, var(--ink)) 100%);
    opacity: 0.9;
  }
  .portrait-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      135deg,
      transparent 0 10px,
      rgba(255,255,255,0.08) 10px 12px
    );
  }
  .portrait-img {
    position: absolute;
    inset: 6%;
    width: 88%;
    height: 88%;
    object-fit: contain;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    z-index: 2;
  }
  .portrait-placeholder {
    position: absolute;
    inset: 12% 10%;
    display: grid;
    place-content: center;
    text-align: center;
    gap: 10px;
    border: 2px dashed rgba(246, 236, 210, 0.55);
    background: rgba(20, 16, 12, 0.35);
    color: var(--cream);
    z-index: 2;
    padding: 10px;
  }
  .ph-tag {
    font-family: var(--font-pixel);
    font-size: 9px;
    color: var(--cream);
    letter-spacing: 2px;
  }
  .ph-hint {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.4;
    color: var(--cream);
    opacity: 0.85;
  }
  .ph-hint code {
    background: rgba(0,0,0,0.4);
    padding: 1px 4px;
    color: var(--cream);
  }
  .codename {
    position: absolute;
    bottom: 6px;
    left: 6px;
    font-family: var(--font-pixel);
    font-size: 8px;
    background: var(--ink);
    color: var(--cream);
    padding: 4px 6px;
    border: 1px solid var(--ink);
    letter-spacing: 1px;
    z-index: 3;
  }

  .card-body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .card-name {
    font-family: var(--font-pixel);
    font-size: 13px;
    color: var(--ink);
    letter-spacing: 1px;
  }
  .card-role {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-dim);
    line-height: 1.4;
  }

  .stats { list-style: none; display: flex; flex-direction: column; gap: 4px; margin-top: 4px; }
  .stat {
    display: grid;
    grid-template-columns: 48px 1fr;
    align-items: center;
    gap: 8px;
    font-family: var(--font-pixel);
    font-size: 8px;
    color: var(--ink-dim);
  }
  .stat-bar {
    height: 8px;
    background: var(--bg-card-2);
    border: 1px solid var(--ink);
    position: relative;
  }
  .stat-fill {
    position: absolute;
    inset: 0;
    width: var(--w);
    background: var(--accent-color);
    box-shadow: inset 0 -2px 0 rgba(0,0,0,0.18);
  }

  .accent-brick  { --accent-color: var(--brick); }
  .accent-gold   { --accent-color: var(--gold); }
  .accent-teal   { --accent-color: var(--teal); }
  .accent-sienna { --accent-color: var(--sienna); }
</style>
