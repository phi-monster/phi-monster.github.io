---
/*
 * HeroVS — pure HTML/CSS title screen.
 *
 * Composition: AGENT-α (image slot) ⚡ Φ-badge "VS" ⚡ AGENT-β (image slot),
 * over a sunset arena backdrop. No Phaser, no canvas, no JS — just CSS
 * gradients + animations. Always renders.
 *
 * Sprite slots:
 *   spriteLeft / spriteRight: optional image paths (e.g. "/sprites/alpha.png").
 *   When undefined, a dashed placeholder box shows in their place.
 */

export interface Props {
  spriteLeft?: string;
  spriteRight?: string;
}
const { spriteLeft, spriteRight } = Astro.props;
---
<section class="hero" aria-label="Title screen">
  <!-- Sunset gradient + sun + arena ground are all CSS layers below -->
  <div class="hero-sky" aria-hidden="true"></div>
  <div class="hero-sun" aria-hidden="true"></div>
  <div class="hero-ground" aria-hidden="true">
    <div class="hero-grid"></div>
  </div>

  <!-- Title strip top-center -->
  <div class="hero-title">
    <h1 class="hero-title-main">PHI&nbsp;&nbsp;MONSTER</h1>
    <p class="hero-title-sub">PHYSICAL · WORLD · AI · FIGHTING</p>
  </div>

  <!-- LEFT side: HUD + fighter slot -->
  <div class="side side-left">
    <div class="hud hud-left">
      <span class="hud-stripe" style="background: var(--brick);"></span>
      <div class="hud-text">
        <span class="hud-codename">AGENT · α</span>
        <span class="hud-model" style="color: var(--brick);">VLA  POLICY</span>
        <span class="hud-version">v1.4 · 7B</span>
      </div>
      <div class="hud-bar">
        <span style="background: var(--brick);"></span>
      </div>
    </div>
    <div class="slot slot-left" data-side="left">
      {spriteLeft
        ? <img src={spriteLeft} alt="Agent alpha" />
        : (
          <div class="slot-placeholder">
            <span class="ph-tag">SPRITE · LEFT</span>
            <span class="ph-hint">drop image at<br/><code>/sprites/&lt;file&gt;</code></span>
          </div>
        )
      }
    </div>
  </div>

  <!-- CENTER: Φ "VS" badge -->
  <div class="badge">
    <div class="badge-glow"></div>
    <div class="badge-diamond">
      <div class="badge-inner">
        <span class="badge-phi">Φ</span>
      </div>
    </div>
    <span class="badge-caption">FIGHT</span>
  </div>

  <!-- RIGHT side: fighter slot + HUD -->
  <div class="side side-right">
    <div class="hud hud-right">
      <span class="hud-stripe" style="background: var(--teal);"></span>
      <div class="hud-text">
        <span class="hud-codename">AGENT · β</span>
        <span class="hud-model" style="color: var(--teal);">WORLD  MODEL</span>
        <span class="hud-version">v0.9 · 13B</span>
      </div>
      <div class="hud-bar">
        <span style="background: var(--teal);"></span>
      </div>
    </div>
    <div class="slot slot-right" data-side="right">
      {spriteRight
        ? <img src={spriteRight} alt="Agent beta" />
        : (
          <div class="slot-placeholder">
            <span class="ph-tag">SPRITE · RIGHT</span>
            <span class="ph-hint">drop image at<br/><code>/sprites/&lt;file&gt;</code></span>
          </div>
        )
      }
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="hero-scroll">
    <span class="hero-scroll-text">SCROLL  TO  CONTINUE</span>
    <span class="hero-scroll-chev">▼</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 620px;
    width: 100%;
    overflow: hidden;
    background: var(--bg-hero-0);
    color: var(--cream);
    isolation: isolate;
  }

  /* ─── Sky: vertical gradient ─── */
  .hero-sky {
    position: absolute;
    inset: 0 0 38% 0;
    background: linear-gradient(
      180deg,
      var(--bg-hero-0) 0%,
      var(--bg-hero-1) 45%,
      var(--bg-hero-2) 80%,
      var(--bg-hero-3) 100%
    );
    z-index: 0;
  }

  /* ─── Sun disc behind badge ─── */
  .hero-sun {
    position: absolute;
    left: 50%;
    bottom: 32%;
    transform: translate(-50%, 50%);
    width: 38vh;
    height: 38vh;
    max-width: 380px;
    max-height: 380px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      #f6d39a 0%,
      #f2c388 45%,
      rgba(210, 139, 79, 0.4) 70%,
      transparent 100%
    );
    z-index: 1;
  }

  /* ─── Ground: sienna with perspective grid ─── */
  .hero-ground {
    position: absolute;
    inset: 62% 0 0 0;
    background: linear-gradient(
      180deg,
      var(--bg-hero-ground) 0%,
      #321a18 100%
    );
    z-index: 2;
    perspective: 600px;
    transform-style: preserve-3d;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent 0 calc(100% / 24 - 1px),
        rgba(255,255,255,0.06) calc(100% / 24 - 1px) calc(100% / 24)
      ),
      repeating-linear-gradient(
        180deg,
        transparent 0 24px,
        rgba(255,255,255,0.05) 24px 25px
      );
    transform: rotateX(70deg);
    transform-origin: top center;
  }
  /* Horizon glow line */
  .hero-ground::before {
    content: '';
    position: absolute;
    top: -3px;
    left: 0; right: 0;
    height: 4px;
    background: #f2c388;
    box-shadow: 0 0 14px 2px rgba(242,195,136,0.7);
  }
  /* Ring rope (suggests an arena) */
  .hero-ground::after {
    content: '';
    position: absolute;
    top: 12px; left: 32px; right: 32px; bottom: 12px;
    border: 2px solid var(--ink);
    opacity: 0.45;
    pointer-events: none;
  }

  /* ─── Title strip ─── */
  .hero-title {
    position: absolute;
    top: 6vh;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 6;
    user-select: none;
  }
  .hero-title-main {
    font-family: var(--font-pixel);
    font-size: clamp(18px, 3.4vw, 30px);
    color: var(--cream);
    letter-spacing: 4px;
    text-shadow:
      4px 4px 0 var(--shadow),
      0 0 18px rgba(184,65,44,0.4);
  }
  .hero-title-sub {
    font-family: var(--font-pixel);
    font-size: clamp(8px, 1.1vw, 11px);
    color: var(--gold);
    letter-spacing: 3px;
    margin-top: 12px;
  }

  /* ─── Sides (HUD + sprite slot) ─── */
  .side {
    position: absolute;
    bottom: 12%;
    width: clamp(180px, 24vw, 280px);
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .side-left  { left: clamp(16px, 5vw, 80px); }
  .side-right { right: clamp(16px, 5vw, 80px); }

  /* ─── HUD panel (cream paper) ─── */
  .hud {
    position: relative;
    background: var(--bg-card);
    border: 2px solid var(--ink);
    box-shadow: 4px 4px 0 var(--shadow);
    width: 100%;
    padding: 8px 10px 10px 14px;
    display: grid;
    gap: 4px;
    color: var(--ink);
  }
  .hud-stripe {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 6px;
  }
  .hud-right .hud-stripe { left: auto; right: 0; }
  .hud-text {
    display: grid;
    gap: 2px;
  }
  .hud-codename {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink);
    letter-spacing: 1px;
  }
  .hud-model {
    font-family: var(--font-pixel);
    font-size: 8px;
    letter-spacing: 1px;
  }
  .hud-version {
    font-family: var(--font-pixel);
    font-size: 7px;
    color: var(--ink-soft);
    letter-spacing: 1px;
  }
  .hud-bar {
    margin-top: 4px;
    height: 8px;
    background: var(--shadow);
    position: relative;
    background-image:
      repeating-linear-gradient(
        90deg,
        transparent 0 calc(10% - 1px),
        rgba(0,0,0,0.6) calc(10% - 1px) 10%
      );
  }
  .hud-bar > span {
    display: block;
    height: 100%;
    width: 100%;
    background-image: inherit;
  }
  .hud-right .hud-text { justify-items: end; }

  /* ─── Sprite slot (image or placeholder) ─── */
  .slot {
    width: 100%;
    aspect-ratio: 1 / 1.2;
    position: relative;
    display: grid;
    place-items: end center;
  }
  .slot img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    filter: drop-shadow(0 6px 8px rgba(0,0,0,0.5));
  }
  .slot[data-side="right"] img { transform: scaleX(-1); }
  .slot-placeholder {
    width: 90%;
    height: 90%;
    border: 2px dashed rgba(246, 236, 210, 0.5);
    background: rgba(20, 16, 12, 0.4);
    color: var(--cream);
    display: grid;
    place-content: center;
    text-align: center;
    gap: 8px;
    padding: 12px;
  }
  .ph-tag {
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--gold);
  }
  .ph-hint {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.4;
    color: var(--cream);
    opacity: 0.7;
  }
  .ph-hint code {
    color: var(--gold);
    background: rgba(0,0,0,0.4);
    padding: 1px 4px;
  }

  /* ─── Center Φ "VS" badge ─── */
  .badge {
    position: absolute;
    left: 50%;
    bottom: 30%;
    transform: translate(-50%, 50%);
    z-index: 5;
    display: grid;
    place-items: center;
    width: 160px;
    height: 200px;
  }
  .badge-glow {
    position: absolute;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,150,58,0.6) 0%, transparent 60%);
    animation: pulse 2.4s ease-in-out infinite;
  }
  .badge-diamond {
    width: 130px; height: 130px;
    background: var(--ink);
    transform: rotate(45deg);
    display: grid;
    place-items: center;
    box-shadow: 6px 6px 0 var(--shadow);
    position: relative;
  }
  .badge-inner {
    width: 110px; height: 110px;
    background: var(--brick);
    display: grid;
    place-items: center;
  }
  .badge-phi {
    font-family: var(--font-pixel);
    font-size: 48px;
    color: var(--cream);
    transform: rotate(-45deg);
    text-shadow: 3px 3px 0 var(--shadow);
  }
  .badge-caption {
    position: absolute;
    bottom: -4px;
    font-family: var(--font-pixel);
    font-size: 12px;
    color: var(--gold);
    letter-spacing: 4px;
    text-shadow: 2px 2px 0 var(--shadow);
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1);   opacity: 0.6; }
    50%      { transform: scale(1.1); opacity: 0.9; }
  }

  /* ─── Scroll hint ─── */
  .hero-scroll {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 6;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--cream);
    user-select: none;
  }
  .hero-scroll-text {
    font-family: var(--font-pixel);
    font-size: clamp(8px, 1vw, 11px);
    letter-spacing: 2px;
    color: var(--cream);
    animation: blink 1.6s ease-in-out infinite;
  }
  .hero-scroll-chev {
    font-family: var(--font-pixel);
    font-size: 14px;
    color: var(--gold);
    animation: bob 1s ease-in-out infinite;
  }
  @keyframes blink { 0%, 100% { opacity: 0.95; } 50% { opacity: 0.3; } }
  @keyframes bob   { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(8px); } }

  /* ─── Mobile tweaks ─── */
  @media (max-width: 720px) {
    .hero { min-height: 560px; }
    .side { width: 42vw; bottom: 18%; }
    .side-left  { left: 4vw; }
    .side-right { right: 4vw; }
    .badge { width: 110px; height: 140px; }
    .badge-diamond { width: 90px; height: 90px; }
    .badge-inner   { width: 76px; height: 76px; }
    .badge-phi     { font-size: 32px; }
    .badge-caption { font-size: 10px; bottom: -2px; }
    .hud { padding: 6px 8px 8px 12px; }
    .hud-codename { font-size: 9px; }
    .hud-model { font-size: 7px; }
    .hud-version { font-size: 6px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge-glow, .hero-scroll-text, .hero-scroll-chev { animation: none; }
  }
</style>
