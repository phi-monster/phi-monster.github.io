---
const items: string[] = [
  'INSERT  COIN',
  'PHYSICAL  WORLD  AI  FIGHTING',
  'EST.  2026',
  'NEO·GEO  RESEARCH  LAB',
  'PRONOUNCED  "FIGHT"',
  'ROUND  1 — FIGHT!',
];
const stream = [...items, ...items, ...items];
---
<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    {stream.map((s) => (
      <span class="marquee-item">{s}</span>
      <span class="marquee-sep">◆</span>
    ))}
  </div>
</div>
<style>
  .marquee {
    overflow: hidden;
    background: var(--ink);
    color: var(--bg-0);
    border-top: 4px solid var(--shadow);
    border-bottom: 4px solid var(--shadow);
    font-family: var(--font-pixel);
    font-size: 11px;
    letter-spacing: 2px;
    padding: 10px 0;
    position: relative;
    z-index: 10;
  }
  .marquee-track {
    display: inline-flex;
    gap: 28px;
    white-space: nowrap;
    animation: scroll 60s linear infinite;
    padding-left: 100%;
  }
  .marquee-item, .marquee-sep { display: inline-block; }
  .marquee-sep { color: var(--hot); }
  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-100%); }
  }
</style>
