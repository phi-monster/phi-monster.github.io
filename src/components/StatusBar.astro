---
const now = new Date();
const yyyy = now.getUTCFullYear();
---
<div class="status-bar">
  <span class="seg">
    <span class="dot" />
    <span>STAGE · 0</span>
  </span>
  <span class="seg sep">/</span>
  <span class="seg">EST · 2026</span>
  <span class="seg sep">/</span>
  <span class="seg">© {yyyy} · Φ MONSTER</span>
</div>
<style>
  .status-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--ink);
    color: var(--cream);
    font-family: var(--font-pixel);
    font-size: 8px;
    letter-spacing: 1.5px;
    padding: 8px 14px;
    display: flex;
    gap: 16px;
    align-items: center;
    border-top: 2px solid var(--shadow);
    z-index: 50;
  }
  .seg { display: inline-flex; align-items: center; gap: 6px; color: var(--cream); }
  .sep { color: var(--ink-soft); }
  .dot {
    display: inline-block;
    width: 8px; height: 8px;
    background: var(--gold);
    box-shadow: 0 0 6px var(--gold);
    animation: blink 1.6s steps(2) infinite;
  }
  @keyframes blink {
    0%, 60% { opacity: 1; }
    61%, 100% { opacity: 0.25; }
  }
  @media (max-width: 640px) {
    .status-bar { font-size: 7px; gap: 8px; padding: 6px 8px; }
    .sep { display: none; }
  }
</style>
