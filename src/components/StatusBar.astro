---
const now = new Date();
const yyyy = now.getUTCFullYear();
---
<div class="status-bar">
  <span class="seg">
    <span class="dot" />
    <span>SYS · ONLINE</span>
  </span>
  <span class="seg">CRT · 0.18</span>
  <span class="seg sep">/</span>
  <span class="seg">FPS · 60</span>
  <span class="seg sep">/</span>
  <span class="seg">© {yyyy} PHI MONSTER</span>
</div>
<style>
  .status-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--shadow);
    color: var(--ink-dim);
    font-family: var(--font-pixel);
    font-size: 8px;
    letter-spacing: 1.5px;
    padding: 8px 14px;
    display: flex;
    gap: 16px;
    align-items: center;
    border-top: 2px solid var(--bg-2);
    z-index: 50;
    backdrop-filter: blur(2px);
  }
  .seg { display: inline-flex; align-items: center; gap: 6px; }
  .sep { color: var(--bg-2); }
  .dot {
    display: inline-block;
    width: 8px; height: 8px;
    background: var(--acid);
    box-shadow: 0 0 6px var(--acid);
    animation: blink 1.4s steps(2) infinite;
  }
  @keyframes blink {
    0%, 60% { opacity: 1; }
    61%, 100% { opacity: 0.2; }
  }
  @media (max-width: 640px) {
    .status-bar { font-size: 7px; gap: 8px; padding: 6px 8px; }
    .sep { display: none; }
  }
</style>
