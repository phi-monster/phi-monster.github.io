---
import Base from '../layouts/Base.astro';
import HeroVS from '../components/HeroVS.astro';
import Marquee from '../components/Marquee.astro';
import FighterCard from '../components/FighterCard.astro';
import StatusBar from '../components/StatusBar.astro';

// Research vectors. `image` slot is a path under /public/sprites/ —
// drop a PNG there to fill the portrait. When undefined, a "SPRITE
// PENDING" placeholder shows.
const fighters = [
  {
    name: 'ADVERSARIAL  VLA',
    codename: 'ROUND·01',
    role: 'robustness of vision-language-action systems under live adversaries',
    accent: 'brick' as const,
    stats: { ROBUST: 6, INTERP: 7, SCALE: 8, ADV: 9 },
  },
  {
    name: 'CONTESTED  WORLD',
    codename: 'ROUND·02',
    role: 'world models when an opponent shapes the dynamics',
    accent: 'gold' as const,
    stats: { ROBUST: 7, INTERP: 6, SCALE: 7, ADV: 9 },
  },
  {
    name: 'SELF-PLAY  CIRCUITS',
    codename: 'ROUND·03',
    role: 'mechanistic interpretability of self-play policies',
    accent: 'teal' as const,
    stats: { ROBUST: 5, INTERP: 10, SCALE: 6, ADV: 7 },
  },
  {
    name: 'ENERGY-BOUNDED',
    codename: 'ROUND·04',
    role: 'strategic emergence under hard physical constraints',
    accent: 'sienna' as const,
    stats: { ROBUST: 8, INTERP: 7, SCALE: 5, ADV: 8 },
  },
  {
    name: 'SAMPLE-EFFICIENT',
    codename: 'ROUND·05',
    role: 'opponent-distribution coverage without league-scale compute',
    accent: 'brick' as const,
    stats: { ROBUST: 7, INTERP: 5, SCALE: 9, ADV: 7 },
  },
  {
    name: 'CROSS-EMBODIMENT',
    codename: 'ROUND·06',
    role: 'adversarial generalization across body morphologies',
    accent: 'teal' as const,
    stats: { ROBUST: 9, INTERP: 6, SCALE: 7, ADV: 6 },
  },
];

const team = [
  {
    name: 'LIU  YUCHEN',
    handle: 'liu.yuchen',
    role: 'FOUNDER · researcher',
    affiliation: 'HKUST · undergraduate',
    bio: 'Started Φ in 2026. Working on world models under adversarial dynamics and the mechanistic interpretability of self-play policies.',
    accent: 'brick' as const,
  },
  {
    name: 'CHALLENGER  · 02',
    handle: '???',
    role: 'co-founder · pending',
    affiliation: 'HKUST',
    bio: 'Recruiting. If you are doing serious research in physical-world AI fighting and want a long-term home for it, the slot is open.',
    accent: 'gold' as const,
  },
];

const notRules = [
  ['NOT', 'a startup, no equity, no product roadmap'],
  ['NOT', 'a graduate program or substitute for one'],
  ['NOT', 'a credential — Φ work makes a Φ researcher, not the badge'],
  ['NOT', 'a brand for status'],
  ['NOT', 'a robotics fighting league — the fight is inside the AI'],
];

const news = [
  {
    date: '2026 · 05',
    tag: 'STAGE 0',
    title: 'Φ founded · domain online · first grant applications submitted',
    venue: '—',
  },
  {
    date: '2026 · Q4',
    tag: 'EXPECTED',
    title: 'first preprints · ICLR 2027 submissions',
    venue: 'arXiv',
  },
  {
    date: '2027+',
    tag: 'PIPELINE',
    title: 'sustained publication output across ICLR / NeurIPS / ICML / CoRL / RSS',
    venue: 'open access',
  },
];
---

<Base>
  <HeroVS />

  <Marquee />

  <main id="main-content">
    <!-- ROUND 1: ABOUT -->
    <section class="block" id="about">
      <header class="block-header">
        <span class="block-tag">ROUND  01</span>
        <h2 class="block-title">WHAT  IS  Φ ?</h2>
      </header>
      <div class="about-body">
        <p class="lead">
          <strong>Φ</strong> is an independent research collective for
          <strong>physical-world AI fighting</strong>. The symbol is Φ. We
          pronounce it <em>"fight"</em>.
        </p>
        <p>
          We study how physical-world AI systems &mdash; vision-language-action
          models, world models, and whatever architectural categories come next
          &mdash; learn, fail, and adapt when made to fight other physical-world
          AI systems. The fighting we care about is what happens
          <em>inside</em> the intelligence: the representations, the world
          models, the failure modes, the strategic emergence when one physical
          AI is set against another.
        </p>
        <p>
          We are not a company. We are not a lab in any institution. We are a
          small group of independent researchers working at the intersection
          of multi-agent RL, VLA &amp; world models, mechanistic
          interpretability, contact-rich dynamics, and adversarial self-play.
          Φ is a ten-year project. We publish openly.
        </p>
        <ul class="hud-list">
          <li><span class="hud-key">FIELD</span><span>adversarial multi-agent embodied AI</span></li>
          <li><span class="hud-key">MODE</span><span>independent · open · part-time · distributed</span></li>
          <li><span class="hud-key">FOUNDER</span><span>Liu Yuchen — HKUST</span></li>
          <li><span class="hud-key">EST.</span><span>2026 · ten-year arc</span></li>
        </ul>
      </div>
    </section>

    <!-- ROUND 2: RESEARCH VECTORS -->
    <section class="block" id="fighters">
      <header class="block-header">
        <span class="block-tag">ROUND  02</span>
        <h2 class="block-title">CHOOSE  YOUR  FIGHTER</h2>
        <p class="block-sub">active and planned research vectors</p>
      </header>
      <div class="grid">
        {fighters.map((f) => <FighterCard {...f} />)}
      </div>
    </section>

    <!-- ROUND 3: TEAM -->
    <section class="block" id="team">
      <header class="block-header">
        <span class="block-tag">ROUND  03</span>
        <h2 class="block-title">FIGHTERS</h2>
        <p class="block-sub">the people who do the work</p>
      </header>
      <div class="team-grid">
        {team.map((p, i) => (
          <article class={`person accent-${p.accent}`}>
            <div class="person-portrait">
              <div class="portrait-bg" aria-hidden="true"></div>
              <div class="portrait-placeholder">
                <span class="ph-tag">PORTRAIT  PENDING</span>
              </div>
            </div>
            <div class="person-info">
              <span class="person-tag">PLAYER · {String(i + 1).padStart(2, '0')}</span>
              <h3 class="person-name">{p.name}</h3>
              <p class="person-role">{p.role}</p>
              <p class="person-aff">{p.affiliation}</p>
              <p class="person-bio">{p.bio}</p>
              <div class="person-handle">@{p.handle}</div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ROUND 4: PUBLICATIONS / NEWS -->
    <section class="block" id="publications">
      <header class="block-header">
        <span class="block-tag">ROUND  04</span>
        <h2 class="block-title">FIGHT  RECORD</h2>
        <p class="block-sub">publications &amp; status updates · open access by default</p>
      </header>
      <ol class="news-list">
        {news.map((n) => (
          <li class="news-item">
            <span class="news-date">{n.date}</span>
            <span class="news-tag">{n.tag}</span>
            <span class="news-title">{n.title}</span>
            <span class="news-venue">{n.venue}</span>
          </li>
        ))}
      </ol>
      <p class="news-note">
        No preprints yet. First arXiv submissions expected late 2026 /
        early 2027. All Φ-affiliated work appears under open licenses
        with reproducible code, on arXiv and at appropriate venues
        (ICLR, NeurIPS, ICML, CoRL, RSS, and their workshops).
      </p>
    </section>

    <!-- ROUND 5: WHY THIS REGIME -->
    <section class="block" id="why">
      <header class="block-header">
        <span class="block-tag">ROUND  05</span>
        <h2 class="block-title">WHY  THIS  REGIME</h2>
      </header>
      <div class="why-body">
        <p>
          Mainstream physical AI optimizes single agents in cooperative or
          static environments. <em>Pick up the cube. Walk on the terrain. Don't fall.</em>
          This is not the regime in which physical intelligence will actually
          have to operate.
        </p>
        <p>
          The hardest, most informative tests of a physical AI system are not
          how well it performs alone, but how it behaves when another physical
          AI is actively trying to defeat it. This is where:
        </p>
        <ul class="why-list">
          <li>world models break in the most interesting ways</li>
          <li>self-play produces the most surprising emergent behaviors</li>
          <li>VLA systems reveal their hidden vulnerabilities</li>
          <li>interpretability has the most leverage</li>
          <li>realistic curricula for general physical intelligence will eventually come from</li>
        </ul>
        <p>
          The regime sits awkwardly between multi-agent RL (mostly toy
          domains), embodied AI (mostly single agents), and interpretability
          (mostly language models). Φ exists to occupy that intersection
          seriously.
        </p>
      </div>
    </section>

    <!-- ROUND 6: WHAT WE ARE NOT -->
    <section class="block" id="manifesto">
      <header class="block-header">
        <span class="block-tag">ROUND  06</span>
        <h2 class="block-title">WHAT  WE  ARE  NOT</h2>
      </header>
      <ol class="manifesto">
        {notRules.map(([k, v]) => (
          <li><span class="m-num">{k}</span><span>{v}</span></li>
        ))}
      </ol>
    </section>

    <!-- FINAL ROUND: CONTACT -->
    <section class="block" id="contact">
      <header class="block-header">
        <span class="block-tag">FINAL  ROUND</span>
        <h2 class="block-title">CHALLENGE  US</h2>
        <p class="block-sub">
          serious researchers in adversarial physical AI, self-play interpretability,
          or contested world models — reach out.
        </p>
      </header>
      <div class="contact-grid">
        <a class="contact-card" href="https://github.com/phi-monster" target="_blank" rel="noreferrer">
          <span class="cc-key">GITHUB</span>
          <span class="cc-val">github.com/phi-monster</span>
        </a>
        <a class="contact-card" href="mailto:hello@xn--n5h.monster">
          <span class="cc-key">MAIL</span>
          <span class="cc-val">hello@φ.monster</span>
        </a>
        <div class="contact-card">
          <span class="cc-key">STATUS</span>
          <span class="cc-val">Stage 0 · first preprints late 2026 / early 2027</span>
        </div>
      </div>
    </section>

    <footer class="footer">
      <p>© <span id="yr"></span> &nbsp;Φ&nbsp; — when the work is good enough, the rest will explain itself</p>
      <p class="footer-sub">no quarter given</p>
    </footer>
  </main>

  <StatusBar />
</Base>

<script>
  const yr = document.getElementById('yr');
  if (yr) yr.textContent = String(new Date().getUTCFullYear());
</script>

<style>
  /* ─── Main content ─── */
  #main-content {
    padding-bottom: 80px;
    background: var(--bg-page);
  }

  /* ─── Block / section base ─── */
  .block {
    max-width: 1100px;
    margin: 0 auto;
    padding: 64px 24px;
  }
  .block-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 32px;
    border-left: 6px solid var(--brick);
    padding-left: 16px;
  }
  .block-tag {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--sienna);
    letter-spacing: 3px;
  }
  .block-title {
    font-family: var(--font-pixel);
    font-size: clamp(20px, 3.6vw, 32px);
    color: var(--ink);
    letter-spacing: 2px;
  }
  .block-sub {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-dim);
  }

  /* ─── About ─── */
  .about-body { display: grid; gap: 18px; }
  .lead {
    font-family: var(--font-mono);
    font-size: clamp(16px, 2.2vw, 20px);
    line-height: 1.6;
    color: var(--ink);
  }
  .lead strong { color: var(--brick); font-weight: 700; }
  .lead em { color: var(--sienna); font-style: italic; }
  .about-body p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-dim);
  }
  .about-body p em { color: var(--brick); font-style: italic; }
  .hud-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 8px;
    margin-top: 12px;
    border-top: 1px dashed var(--paper-line);
    padding-top: 16px;
  }
  .hud-list li {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 12px;
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 1px;
    line-height: 1.6;
    color: var(--ink);
  }
  .hud-key { color: var(--teal); }

  /* ─── Why ─── */
  .why-body {
    display: grid;
    gap: 18px;
    font-family: var(--font-mono);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-dim);
  }
  .why-body em { color: var(--brick); font-style: italic; }
  .why-list {
    list-style: none;
    display: grid;
    gap: 8px;
    padding: 18px 22px;
    background: var(--bg-card);
    border: 1px solid var(--paper-line);
    border-left: 4px solid var(--gold);
  }
  .why-list li {
    position: relative;
    padding-left: 22px;
    color: var(--ink);
  }
  .why-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--brick);
  }

  /* ─── Fighters grid ─── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 22px;
  }

  /* ─── Team / People ─── */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 22px;
  }
  .person {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 16px;
    background: var(--bg-card);
    border: 3px solid var(--ink);
    box-shadow: 5px 5px 0 var(--shadow);
    transition: transform 120ms ease, box-shadow 120ms ease;
  }
  .person:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 var(--shadow);
  }
  .person-portrait {
    position: relative;
    overflow: hidden;
    border-right: 3px solid var(--ink);
    aspect-ratio: 1 / 1;
    min-height: 130px;
  }
  .portrait-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        var(--accent-color) 0%,
        color-mix(in srgb, var(--accent-color) 60%, var(--ink)) 100%);
    opacity: 0.9;
  }
  .portrait-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      135deg,
      transparent 0 10px,
      rgba(255,255,255,0.08) 10px 12px
    );
  }
  .portrait-placeholder {
    position: absolute;
    inset: 14% 12%;
    display: grid;
    place-content: center;
    text-align: center;
    border: 2px dashed rgba(246, 236, 210, 0.5);
    background: rgba(20, 16, 12, 0.3);
    color: var(--cream);
    z-index: 2;
  }
  .person-portrait .ph-tag {
    font-family: var(--font-pixel);
    font-size: 7px;
    letter-spacing: 1px;
  }
  .person-info {
    padding: 14px 16px 16px 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .person-tag {
    font-family: var(--font-pixel);
    font-size: 8px;
    color: var(--accent-color);
    letter-spacing: 2px;
  }
  .person-name {
    font-family: var(--font-pixel);
    font-size: 14px;
    color: var(--ink);
    letter-spacing: 1px;
    margin-top: 2px;
  }
  .person-role {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-dim);
  }
  .person-aff {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
  }
  .person-bio {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink);
    line-height: 1.5;
    margin-top: 6px;
  }
  .person-handle {
    font-family: var(--font-pixel);
    font-size: 8px;
    color: var(--accent-color);
    margin-top: auto;
    padding-top: 8px;
    letter-spacing: 1px;
  }
  .accent-brick  { --accent-color: var(--brick); }
  .accent-gold   { --accent-color: var(--gold); }
  .accent-teal   { --accent-color: var(--teal); }
  .accent-sienna { --accent-color: var(--sienna); }

  /* ─── News / Publications ─── */
  .news-list {
    list-style: none;
    display: grid;
    gap: 0;
    border: 1px solid var(--paper-line);
    background: var(--bg-card);
  }
  .news-item {
    display: grid;
    grid-template-columns: 90px 80px 1fr 90px;
    gap: 16px;
    padding: 14px 18px;
    border-bottom: 1px dashed var(--paper-line);
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--ink);
    align-items: baseline;
  }
  .news-item:last-child { border-bottom: 0; }
  .news-date {
    font-family: var(--font-pixel);
    font-size: 9px;
    color: var(--teal);
    letter-spacing: 1px;
  }
  .news-tag {
    font-family: var(--font-pixel);
    font-size: 8px;
    color: var(--cream);
    background: var(--brick);
    padding: 4px 6px;
    letter-spacing: 1px;
    text-align: center;
  }
  .news-venue {
    font-family: var(--font-pixel);
    font-size: 8px;
    color: var(--ink-soft);
    letter-spacing: 1px;
    text-align: right;
  }
  .news-note {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--ink-dim);
    line-height: 1.6;
    margin-top: 16px;
    padding: 14px 18px;
    background: var(--bg-card-2);
    border-left: 4px solid var(--gold);
  }
  @media (max-width: 720px) {
    .news-item {
      grid-template-columns: 1fr;
      gap: 4px;
    }
    .news-venue { text-align: left; }
  }

  /* ─── Manifesto / Not list ─── */
  .manifesto {
    list-style: none;
    display: grid;
    gap: 10px;
  }
  .manifesto li {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 18px;
    align-items: baseline;
    background: var(--bg-card);
    border: 1px solid var(--paper-line);
    border-left: 4px solid var(--brick);
    padding: 16px 18px;
    font-family: var(--font-mono);
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink);
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .manifesto li:hover {
    border-left-color: var(--gold);
    transform: translateX(4px);
  }
  .m-num {
    font-family: var(--font-pixel);
    font-size: 14px;
    color: var(--brick);
    letter-spacing: 2px;
  }

  /* ─── Contact ─── */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
  }
  .contact-card {
    display: grid;
    gap: 6px;
    padding: 22px;
    background: var(--bg-card);
    border: 3px solid var(--ink);
    box-shadow: 5px 5px 0 var(--shadow);
    transition: transform 120ms ease, box-shadow 120ms ease;
    color: var(--ink);
    border-bottom: 3px solid var(--ink);
  }
  a.contact-card { border-bottom: 3px solid var(--ink); }
  a.contact-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 7px 0 var(--shadow);
    color: var(--brick);
    background: var(--bg-card-2);
  }
  .cc-key {
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--teal);
  }
  .cc-val {
    font-family: var(--font-mono);
    font-size: 16px;
    color: inherit;
    word-break: break-all;
  }

  /* ─── Footer ─── */
  .footer {
    text-align: center;
    margin-top: 48px;
    padding: 24px;
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-dim);
    letter-spacing: 2px;
  }
  .footer-sub {
    font-size: 8px;
    color: var(--brick);
    margin-top: 8px;
  }
</style>
