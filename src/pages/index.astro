---
import Base from '../layouts/Base.astro';
import Marquee from '../components/Marquee.astro';
import FighterCard from '../components/FighterCard.astro';
import StatusBar from '../components/StatusBar.astro';

const fighters = [
  {
    name: 'ADVERSARIAL  VLA',
    codename: 'ROUND·01',
    role: 'robustness of vision-language-action systems under live adversaries',
    glyph: 'α',
    accent: 'hot' as const,
    stats: { ROBUST: 6, INTERP: 7, SCALE: 8, ADV: 9 },
  },
  {
    name: 'CONTESTED  WORLD',
    codename: 'ROUND·02',
    role: 'world models when an opponent shapes the dynamics',
    glyph: 'β',
    accent: 'gold' as const,
    stats: { ROBUST: 7, INTERP: 6, SCALE: 7, ADV: 9 },
  },
  {
    name: 'SELF-PLAY  CIRCUITS',
    codename: 'ROUND·03',
    role: 'mechanistic interpretability of self-play policies',
    glyph: 'γ',
    accent: 'neon' as const,
    stats: { ROBUST: 5, INTERP: 10, SCALE: 6, ADV: 7 },
  },
  {
    name: 'ENERGY-BOUNDED',
    codename: 'ROUND·04',
    role: 'strategic emergence under hard physical constraints',
    glyph: 'δ',
    accent: 'acid' as const,
    stats: { ROBUST: 8, INTERP: 7, SCALE: 5, ADV: 8 },
  },
  {
    name: 'SAMPLE-EFFICIENT',
    codename: 'ROUND·05',
    role: 'opponent-distribution coverage without league-scale compute',
    glyph: 'ε',
    accent: 'blood' as const,
    stats: { ROBUST: 7, INTERP: 5, SCALE: 9, ADV: 7 },
  },
  {
    name: 'CROSS-EMBODIMENT',
    codename: 'ROUND·06',
    role: 'adversarial generalization across body morphologies',
    glyph: 'ζ',
    accent: 'hot' as const,
    stats: { ROBUST: 9, INTERP: 6, SCALE: 7, ADV: 6 },
  },
];

const notRules = [
  ['NOT', 'a startup, no equity, no product roadmap'],
  ['NOT', 'a graduate program or substitute for one'],
  ['NOT', 'a credential — Φ work makes a Φ researcher, not the badge'],
  ['NOT', 'a brand for status'],
  ['NOT', 'a robotics fighting league — the fight is inside the AI'],
];
---

<Base>
  <!-- ARCADE TITLE / PHASER STAGE -->
  <section id="arcade-stage" aria-label="Title screen">
    <div id="phaser-mount"></div>
    <noscript>
      <div class="noscript-card">
        <h1>Φ MONSTER</h1>
        <p>Independent research collective for physical-world AI fighting.</p>
        <p>JavaScript is required for the arcade title screen. Continue below.</p>
      </div>
    </noscript>
    <button id="skip-intro" type="button" aria-label="Skip intro">SKIP ▾</button>
  </section>

  <Marquee />

  <!-- MAIN CONTENT -->
  <main id="main-content">
    <!-- ROUND 1: ABOUT -->
    <section class="block" id="about">
      <header class="block-header">
        <span class="block-tag">ROUND  01</span>
        <h2 class="block-title">WHAT  IS  Φ ?</h2>
      </header>
      <div class="block-body about-body">
        <p class="lead">
          <strong>Φ</strong> is an independent research collective for
          <strong>physical-world AI fighting</strong>. The symbol is Φ. We
          pronounce it <em>"fight"</em>.
        </p>
        <p>
          We study how physical-world AI systems &mdash; vision-language-action
          models, world models, and whatever architectural categories come next
          &mdash; learn, fail, and adapt when made to fight other physical-world
          AI systems. The fighting we care about is what happens
          <em>inside</em> the intelligence: the representations, the world
          models, the failure modes, the strategic emergence when one physical
          AI is set against another.
        </p>
        <p>
          We are not a company. We are not a lab in any institution. We are a
          small group of independent researchers working at the intersection
          of multi-agent RL, VLA &amp; world models, mechanistic
          interpretability, contact-rich dynamics, and adversarial self-play.
          Φ is a ten-year project. We publish openly.
        </p>
        <ul class="hud-list">
          <li><span class="hud-key">FIELD</span><span>adversarial multi-agent embodied AI</span></li>
          <li><span class="hud-key">MODE</span><span>independent · open · part-time · distributed</span></li>
          <li><span class="hud-key">FOUNDER</span><span>Liu Yuchen — HKUST</span></li>
          <li><span class="hud-key">EST.</span><span>2026 · ten-year arc</span></li>
        </ul>
      </div>
    </section>

    <!-- ROUND 2: FIGHTERS / RESEARCH -->
    <section class="block" id="fighters">
      <header class="block-header">
        <span class="block-tag">ROUND  02</span>
        <h2 class="block-title">CHOOSE  YOUR  FIGHTER</h2>
        <p class="block-sub">active and planned research vectors</p>
      </header>
      <div class="grid">
        {fighters.map((f) => <FighterCard {...f} />)}
      </div>
    </section>

    <!-- ROUND 3: WHY -->
    <section class="block" id="why">
      <header class="block-header">
        <span class="block-tag">ROUND  03</span>
        <h2 class="block-title">WHY  THIS  REGIME</h2>
      </header>
      <div class="why-body">
        <p>
          Mainstream physical AI optimizes single agents in cooperative or
          static environments. <em>Pick up the cube. Walk on the terrain. Don't fall.</em>
          This is not the regime in which physical intelligence will actually
          have to operate.
        </p>
        <p>
          The hardest, most informative tests of a physical AI system are not
          how well it performs alone, but how it behaves when another physical
          AI is actively trying to defeat it. This is where:
        </p>
        <ul class="why-list">
          <li>world models break in the most interesting ways</li>
          <li>self-play produces the most surprising emergent behaviors</li>
          <li>VLA systems reveal their hidden vulnerabilities</li>
          <li>interpretability has the most leverage</li>
          <li>realistic curricula for general physical intelligence will eventually come from</li>
        </ul>
        <p>
          The regime sits awkwardly between multi-agent RL (mostly toy
          domains), embodied AI (mostly single agents), and interpretability
          (mostly language models). Φ exists to occupy that intersection
          seriously.
        </p>
      </div>
    </section>

    <!-- ROUND 4: WHAT WE ARE NOT -->
    <section class="block" id="manifesto">
      <header class="block-header">
        <span class="block-tag">ROUND  04</span>
        <h2 class="block-title">WHAT  WE  ARE  NOT</h2>
      </header>
      <ol class="manifesto">
        {notRules.map(([k, v]) => (
          <li><span class="m-num">{k}</span><span>{v}</span></li>
        ))}
      </ol>
    </section>

    <!-- FINAL ROUND: CONTACT -->
    <section class="block" id="contact">
      <header class="block-header">
        <span class="block-tag">FINAL  ROUND</span>
        <h2 class="block-title">CHALLENGE  US</h2>
        <p class="block-sub">
          serious researchers in adversarial physical AI, self-play interpretability,
          or contested world models — reach out.
        </p>
      </header>
      <div class="contact-grid">
        <a class="contact-card" href="https://github.com/phi-monster" target="_blank" rel="noreferrer">
          <span class="cc-key">GITHUB</span>
          <span class="cc-val">github.com/phi-monster</span>
        </a>
        <a class="contact-card" href="mailto:hello@xn--n5h.monster">
          <span class="cc-key">MAIL</span>
          <span class="cc-val">hello@φ.monster</span>
        </a>
        <div class="contact-card">
          <span class="cc-key">STATUS</span>
          <span class="cc-val">Stage 0 · first preprints late 2026 / early 2027</span>
        </div>
      </div>
    </section>

    <footer class="footer">
      <p>© <span id="yr"></span> &nbsp;Φ&nbsp; — when the work is good enough, the rest will explain itself</p>
      <p class="footer-sub">no quarter given</p>
    </footer>
  </main>

  <StatusBar />
</Base>

<script>
  import { bootArcade } from '../game/boot';

  bootArcade('phaser-mount');

  const skipBtn = document.getElementById('skip-intro');
  skipBtn?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('phi:start'));
  });

  const yr = document.getElementById('yr');
  if (yr) yr.textContent = String(new Date().getUTCFullYear());

  const main = document.getElementById('main-content');
  let revealed = false;
  const reveal = () => {
    if (revealed) return;
    revealed = true;
    main?.classList.add('reveal');
  };
  window.addEventListener('scroll', reveal, { passive: true, once: true });
  document.addEventListener('phi:start', reveal);
</script>

<style>
  /* ─── Arcade stage ─── */
  #arcade-stage {
    position: relative;
    height: 100vh;
    min-height: 560px;
    width: 100%;
    overflow: hidden;
  }
  #phaser-mount { position: absolute; inset: 0; }
  #phaser-mount canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }
  #skip-intro {
    position: absolute;
    bottom: 22px;
    right: 22px;
    background: transparent;
    border: 2px solid var(--ink-dim);
    color: var(--ink-dim);
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 2px;
    padding: 8px 12px;
    box-shadow: 3px 3px 0 var(--shadow);
    z-index: 5;
  }
  #skip-intro:hover {
    color: var(--gold);
    border-color: var(--gold);
    background: transparent;
  }
  .noscript-card {
    position: absolute;
    inset: 12% 8%;
    display: grid;
    place-content: center;
    text-align: center;
    background: var(--bg-1);
    border: 3px solid var(--ink);
    padding: 32px;
    z-index: 2;
  }
  .noscript-card h1 {
    font-family: var(--font-pixel);
    font-size: 32px;
    color: var(--gold);
    margin-bottom: 16px;
  }

  /* ─── Main reveal ─── */
  #main-content {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 700ms ease, transform 700ms ease;
    padding-bottom: 80px;
  }
  #main-content.reveal { opacity: 1; transform: translateY(0); }

  /* ─── Block / section base ─── */
  .block {
    max-width: 1100px;
    margin: 0 auto;
    padding: 64px 24px;
  }
  .block-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 32px;
    border-left: 6px solid var(--hot);
    padding-left: 16px;
  }
  .block-tag {
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--gold);
    letter-spacing: 3px;
  }
  .block-title {
    font-family: var(--font-pixel);
    font-size: clamp(20px, 3.6vw, 32px);
    color: var(--ink);
    letter-spacing: 2px;
    text-shadow: 3px 3px 0 var(--shadow);
  }
  .block-sub {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-dim);
  }

  /* ─── About ─── */
  .about-body { display: grid; gap: 18px; }
  .lead {
    font-family: var(--font-mono);
    font-size: clamp(16px, 2.2vw, 20px);
    line-height: 1.55;
    color: var(--ink);
  }
  .lead strong { color: var(--gold); }
  .lead em { color: var(--hot); font-style: normal; }
  .about-body p {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-dim);
  }
  .about-body p em { color: var(--hot); font-style: italic; }
  .hud-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 8px;
    margin-top: 12px;
    border-top: 2px dashed var(--bg-2);
    padding-top: 16px;
  }
  .hud-list li {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 12px;
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 1px;
    line-height: 1.6;
    color: var(--ink-dim);
  }
  .hud-key { color: var(--neon); }

  /* ─── Why ─── */
  .why-body {
    display: grid;
    gap: 18px;
    font-family: var(--font-mono);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-dim);
  }
  .why-body em { color: var(--hot); font-style: italic; }
  .why-list {
    list-style: none;
    display: grid;
    gap: 8px;
    padding: 16px 18px;
    background: var(--bg-1);
    border-left: 4px solid var(--gold);
  }
  .why-list li {
    position: relative;
    padding-left: 22px;
    color: var(--ink);
  }
  .why-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--hot);
  }

  /* ─── Fighters grid ─── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 22px;
  }

  /* ─── Manifesto / Not list ─── */
  .manifesto {
    list-style: none;
    display: grid;
    gap: 10px;
  }
  .manifesto li {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 18px;
    align-items: baseline;
    background: var(--bg-1);
    border-left: 4px solid var(--blood);
    padding: 16px 18px;
    font-family: var(--font-mono);
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink);
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .manifesto li:hover {
    border-color: var(--gold);
    transform: translateX(4px);
  }
  .m-num {
    font-family: var(--font-pixel);
    font-size: 14px;
    color: var(--blood);
    letter-spacing: 2px;
  }

  /* ─── Contact ─── */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
  }
  .contact-card {
    display: grid;
    gap: 6px;
    padding: 22px;
    background: var(--bg-1);
    border: 3px solid var(--ink);
    box-shadow: 5px 5px 0 var(--shadow);
    transition: transform 120ms ease, box-shadow 120ms ease;
    color: var(--ink);
  }
  a.contact-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 7px 0 var(--shadow);
    color: var(--gold);
  }
  .cc-key {
    font-family: var(--font-pixel);
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--neon);
  }
  .cc-val {
    font-family: var(--font-mono);
    font-size: 16px;
    color: inherit;
    word-break: break-all;
  }

  /* ─── Footer ─── */
  .footer {
    text-align: center;
    margin-top: 48px;
    padding: 24px;
    font-family: var(--font-pixel);
    font-size: 10px;
    color: var(--ink-dim);
    letter-spacing: 2px;
  }
  .footer-sub {
    font-size: 8px;
    color: var(--hot);
    margin-top: 8px;
  }
</style>
